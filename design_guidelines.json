    "menu_seafood": "https://images.unsplash.com/photo-1607375658859-39f31567ce13?crop=entropy&cs=srgb\u0026fm=jpg\u0026ixid=M3w4NjAzNzl8MHwxfHNlYXJjaHwxfHxzZWFmb29kJTIwcGFzdGElMjBwbGF0dGVyJTIwaXRhbGlhbnxlbnwwfHx8fDE3NzM0NTEwMDV8MA\u0026ixlib=rb-4.1.0\u0026q=85",
    "menu_pasta": "https://images.unsplash.com/photo-1612966893103-790e549a2ab1?crop=entropy&cs=srgb&fm=jpg&q=85",
    "menu_dessert": "https://images.unsplash.com/photo-1580876205974-a8d6894b0f71?crop=entropy&cs=srgb&fm=jpg&q=85",
    "menu_salad": "https://images.unsplash.com/photo-1676300185089-8781af127fee?crop=entropy&cs=srgb&fm=jpg&q=85",
    "gallery_1": "https://images.unsplash.com/photo-1553632544-9bae92ffb225?crop=entropy&cs=srgb&fm=jpg&q=85",
    "gallery_2": "https://images.unsplash.com/photo-1612966874574-e0a92ad2bc43?crop=entropy&cs=srgb&fm=jpg&q=85"
  },
  "content_strategy": {
    "voice": "Welcoming, passionate, authentic, professional.",
    "multilingual": "Implement a context provider for language state. Default to SK.",
    "placeholders": {
      "address": "Farská 1315/38, 949 01 Nitra, Slovakia",
      "phone": "+421 917 123 456",
      "email": "info@boccaccio.sk",
      "founder": "Oreste Calzolari (Est. 1997)"
    }
  },
  "accessibility": {
    "contrast": "Ensure text on images has a dark overlay or text-shadow.",
    "motion": "Respect 'prefers-reduced-motion'.",
    "semantic_html": "Use <article> for menu items, <section> for major blocks."
  },
  "universal_guidelines": [
    "Do NOT use 'Inter' font.",
    "Do NOT use gradients for text.",
    "Do NOT use pure black (#000000).",
    "ALWAYS use Lenis for smooth scrolling.",
    "ALWAYS add data-testid to interactive elements.",
    "Ensure the design feels like a 'Tuscan Villa' translated to the web."
  ]
}